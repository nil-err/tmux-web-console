{
  "name": "tmux-web-console",
  "version": "0.1.1",
  "description": "Local web UI for viewing and controlling tmux sessions.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nil-err/tmux-web-console.git"
  },
  "bugs": {
    "url": "https://github.com/nil-err/tmux-web-console/issues"
  },
  "homepage": "https://github.com/nil-err/tmux-web-console#readme",
  "bin": {
    "tmux-web-console": "bin/tmux-web-console.js"
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.14.0",
    "npm": ">=11.5.1"
  },
  "type": "module",
  "scripts": {
    "dev": "tsx src/server/index.ts",
    "dev:host": "HOST=0.0.0.0 npm run dev",
    "build": "vite build && tsc -p tsconfig.node.json",
    "start": "NODE_ENV=production node dist/server/src/server/index.js",
    "start:host": "HOST=0.0.0.0 NODE_ENV=production npm run start",
    "test": "vitest",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.node.json --noEmit"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "express": "^5.2.1",
    "lucide-react": "^1.16.0",
    "node-pty": "^1.1.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^29.1.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
